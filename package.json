{
  "name": "dino-kupinic.dev",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build --preset vercel",
    "dev": "nuxt dev",
    "dev:fast": "NUXT_DEV_PROFILE=fast nuxt dev",
    "dev:fast:host": "NUXT_DEV_PROFILE=fast nuxt dev --host",
    "dev:full": "NUXT_DEV_PROFILE=full nuxt dev",
    "dev:full:host": "NUXT_DEV_PROFILE=full nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "format": "bunx prettier . --check",
    "format:write": "bunx prettier . --write",
    "release": "semantic-release",
    "prepare": "husky"
  },
